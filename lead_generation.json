        100,
        300
      ]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "Industries",
              "value": "[\"Medical Billing\", \"E-Publishing\", \"Customer Experience Services\", \"Healthcare BPO\", \"Digital Publishing\", \"Call Centers\"]"
            },
            {
              "name": "Countries",
              "value": "[\"United States\", \"United Kingdom\", \"Canada\", \"Australia\", \"Germany\"]"
            }
          ]
        },
        "options": {}
      },
      "id": "2",
      "name": "Define Target Audiences",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const industries = JSON.parse($input.first().json.Industries);\nconst countries = JSON.parse($input.first().json.Countries);\n\nconst randomIndustry = industries[Math.floor(Math.random() * industries.length)];\nconst randomCountry = countries[Math.floor(Math.random() * countries.length)];\n\nreturn {\n  query: `\"${randomIndustry}\" companies in ${randomCountry} -jobs -directory`,\n  industry: randomIndustry,\n  country: randomCountry\n};"
      },
      "id": "3",
      "name": "Generate Search Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.tavily.com/search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"api_key\": \"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\", \"query\": $json.query, \"max_results\": 20 } }}",
        "options": {}
      },
      "id": "4",
      "name": "Search Tavily",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        700,
        300
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
