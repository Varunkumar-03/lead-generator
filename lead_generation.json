      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        2300,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json['Company Name']}}",
              "operation": "notEqual",
              "value2": "Unknown"
            },
            {
              "value1": "={{$json['Company Website']}}",
              "operation": "notEmpty"
            }
          ]
        }
      },
