      "name": "Split Tavily Results",
      "type": "n8n-nodes-base.itemLists",
      "typeVersion": 2.1,
      "position": [
        900,
        300
      ],
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "operation": "getAll",
        "documentId": {
          "__rl": true,
          "value": "158RqzkyGQu1NQvckq8pSdYZDVCeKep3fPEcTU6mvr4E",
          "mode": "id"
        },
